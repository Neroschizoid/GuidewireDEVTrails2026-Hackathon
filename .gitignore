# Root .gitignore — Parametric Shield (backend + frontend + ml)

# ─── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg
backend/tests/

# ─── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ─── Secrets / Environment Files ──────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets.json

# ─── JWT / Security ───────────────────────────────────────────
# Never commit secret keys or token logs
*_secret*
*_token*
jwt_*.txt

# ─── Local Database Files ─────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
**/dev.db
**/test.db

# ─── Frontend (React/Vite) ────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*

# ─── ML Artifacts ─────────────────────────────────────────────
ml/__pycache__/
ml/data.csv
ml/*.pkl
ml/*.joblib
ml/*.sav
ml/*.model
ml/*.h5
ml/*.pt
ml/*.onnx

# ─── Node (any subproject) ────────────────────────────────────
**/node_modules/
**/dist/
**/.next/
**/out/

# ─── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Coverage ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
.cache/
