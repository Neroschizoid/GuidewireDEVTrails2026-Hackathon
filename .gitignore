# Combined .gitignore for repo root, backend, and frontend

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Environment / secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
*.pem
*.key
*.crt
secrets.json
*_secret*
*_token*
jwt_*.txt

# Python / backend
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/
.venv/
venv/
env/
ENV/
.conda/
backend/__pycache__/
backend/.pytest_cache/
backend/build/
backend/dist/
backend/*.log
backend/*.pid

# Local databases
*.db
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
backend/dev_hackathon.db
**/dev.db
**/test.db

# Frontend / Node
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
coverage/
.nyc_output/
.cache/
.eslintcache

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend_server.out.log
backend_server.err.log
frontend_server.out.log
frontend_server.err.log

# ML / generated artifacts
ml/__pycache__/
ml/*.pkl
ml/*.joblib
ml/*.sav
ml/*.model
ml/*.h5
ml/*.pt
ml/*.onnx

# Misc
*.bak
*.tmp
*.orig
